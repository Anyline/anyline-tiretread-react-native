{
  "name": "@anyline/tire-tread-react-native-module",
  "version": "1.0.0",
  "description": "React Native SDK for Anyline Tire Tread scanning and depth measurement",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!ios/build",
    "!ios/.build",
    "!ios/Tests",
    "!ios/Tests/**",
    "!android/build",
    "!android/test-runner",
    "!android/test-runner/**",
    "!android/problems.md",
    "!android/src/test",
    "!android/src/test/**",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "app.plugin.js",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepack": "bob build",
    "release:publish:check": "npm run typecheck && npm pack --dry-run",
    "release:publish": "node ./scripts/publish-npm.mjs"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "anyline",
    "tire",
    "tread",
    "scanner",
    "tire-tread",
    "depth-measurement",
    "computer-vision"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anyline/anyline-tiretread-react-native.git"
  },
  "author": "Anyline GmbH (https://anyline.com)",
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/Anyline/anyline-tiretread-react-native/issues"
  },
  "homepage": "https://github.com/Anyline/anyline-tiretread-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@expo/config-plugins": "^9.0.0",
    "@react-native/eslint-config": "^0.73.1",
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.44",
    "del-cli": "^5.1.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "^18.3.1",
    "react-native": "^0.75.5",
    "react-native-builder-bob": "^0.23.2",
    "turbo": "^1.10.7",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "@types/react": "^18.2.44"
  },
  "peerDependencies": {
    "expo": ">=50.0.0",
    "react": "*",
    "react-native": ">=0.75"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "src/generated/",
    "android/build/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
